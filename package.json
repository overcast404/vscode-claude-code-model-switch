{
	"name": "claude-code-model-switch",
	"displayName": "Claude Code Model Switch",
	"description": "为 Claude Code 提供全局和项目级模型一键切换。支持 Anthropic 官方 API、智谱 GLM、Kimi、MiniMax、DeepSeek 等任意兼容 Anthropic 协议的 API 提供商。可按项目独立配置模型和环境变量，互不干扰。",
	"version": "2.1.4",
	"publisher": "overcast404",
	"repository": {
		"type": "git",
		"url": "https://github.com/overcast404/claude-code-model-switch.git"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"claude",
		"claude-code",
		"anthropic",
		"model",
		"switch",
		"zhipu",
		"glm",
		"kimi",
		"deepseek",
		"minimax",
		"dashscope",
		"env",
		"config",
		"project-scope",
		"workspace"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "ccSwitch.selectEnv",
				"title": "切换模型",
				"category": "Claude Code Model Switch"
			},
			{
				"command": "ccSwitch.showConfig",
				"title": "打开配置面板",
				"category": "Claude Code Model Switch"
			},
			{
				"command": "ccSwitch.editSettings",
				"title": "编辑全局 settings.json",
				"category": "Claude Code Model Switch"
			},
			{
				"command": "ccSwitch.editEnvs",
				"title": "编辑全局预设 (envs.json)",
				"category": "Claude Code Model Switch"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "echo 'using pre-compiled JS'"
	}
}
